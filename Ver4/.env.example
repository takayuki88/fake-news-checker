## Ver4 recommended setup: GPT primary review + Gemini evidence review
OPENAI_API_KEY=
OPENAI_PRIMARY_MODEL=gpt-4.1-mini

GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash
GEMINI_STYLE_REVIEW_ENABLED=false
STRICT_POLICY_RESEARCH=false
FETCH_TIMEOUT_SECONDS=12
MAX_FETCH_CHARS=7000
MIN_TEXT_CHARS=10
MIN_AUTO_EXTRACT_CHARS=80
APP_TIMEZONE=Asia/Tokyo
ROBOTS_USER_AGENT=WebPageTrustChecker
APP_HOST=127.0.0.1
APP_PORT=8000
